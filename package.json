{
  "name": "bcv-exchange-rate",
  "version": "1.0.0",
  "description": "Librería profesional de Node.js para el rastreo de indicadores económicos oficiales de Venezuela (BCV) y Colombia (TRM - COP). Especializada en monedas fronterizas.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:types && npm run build:esm:pkg",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build:esm:pkg": "node -e \"require('fs').writeFileSync('dist/esm/package.json', '{\\\"type\\\":\\\"module\\\"}')\"",
    "clean": "rimraf dist coverage",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "lint": "eslint \"**/*.ts\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run clean && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carrilloapps/bcv-exchange-rate.git"
  },
  "keywords": [
    "bcv",
    "trm",
    "venezuela",
    "colombia",
    "cop",
    "ves",
    "frontera",
    "tasa de cambio",
    "exchange-rate",
    "indicadores",
    "economía",
    "scraping"
  ],
  "author": "José Carrillo <m@carrillo.app> (https://carrillo.app)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carrilloapps/bcv-exchange-rate/issues"
  },
  "homepage": "https://github.com/carrilloapps/bcv-exchange-rate#readme",
  "dependencies": {
    "axios": "^1.15.0",
    "cheerio": "^1.2.0"
  },
  "peerDependencies": {
    "winston": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "winston": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
